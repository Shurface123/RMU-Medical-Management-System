# Prevent script execution in upload directory
Options -ExecCGI
RemoveHandler .cgi .pl .py .asp .php .shtml
<FilesMatch "\.(?i:php|php3|php4|php5|phtml|pl|py|jsp|asp|sh|cgi)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Only allow common image formats
<FilesMatch "\.(?i:jpg|jpeg|png|gif|webp)$">
    Order deny,allow
    Allow from all
</FilesMatch>
